{
  "extends": "@prostoprobuy/typescript-config/nextjs.json",
  "compilerOptions": {
    "noUnusedParameters": false,
    "paths": {
      "~*": ["./src/*"],
      "~public/*": ["./public/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
