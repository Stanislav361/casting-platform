{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "build:tma": {
      "dependsOn": ["^build", "^build:tma"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "build:admin": {
      "dependsOn": ["^build", "^build:admin"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "prebuild": {
      "dependsOn": ["^prebuild"]
    },
    "start": {
      "dependsOn": ["^start"]
    },
    "start:tma": {
      "dependsOn": ["^start:tma"]
    },
    "start:admin": {
      "dependsOn": ["^start:admin"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
