# ============================================
# Railway Environment Variables
# Copy these to Railway service variables
# ============================================

# === Backend (core-api) ===

MODE=PROD
LOG_LEVEL=INFO

# PostgreSQL (Railway provides these automatically with Railway Postgres plugin)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=railway

# Redis (Railway provides these automatically with Railway Redis plugin)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Auth
SECRET_KEY=change-this-to-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_HEADER_NAME=Authorization
REFRESH_WEB_TOKEN_CONTAINER_NAME=refresh_web_token
REFRESH_TMA_TOKEN_CONTAINER_NAME=refresh_tma_token
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_HOSTS=https://your-frontend-domain.railway.app

# S3 Storage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_MEDIA_BUCKET_NAME=casting-media
S3_BACKUP_BUCKET_NAME=casting-backup
S3_MEDIA_ENDPOINT_URL=https://storage.yandexcloud.net
S3_BACKUP_ENDPOINT_URL=https://storage.yandexcloud.net

# Telegram Bot
TG_BOT_TOKEN=your-bot-token
TG_BOT_NAME=your_bot_name
TG_TMA_NAME=your_tma_name
TG_CHANEL_NAME=your_channel_name

# VK OAuth (optional)
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Google Services
GOOGLE_DELEGATE_USER=admin@yourdomain.com

# Service
API_SERVICE_NAME=casting-platform

# === Frontend (tma) ===

NEXT_PUBLIC_API_URL=https://your-backend-domain.railway.app/
NEXT_PUBLIC_MODE=production
NEXT_PUBLIC_TELEGRAM_CHANNEL=your_channel_name

# === Frontend (admin) ===

NEXT_PUBLIC_API_URL=https://your-backend-domain.railway.app/
NEXT_PUBLIC_HOST=https://your-admin-domain.railway.app
NEXT_PUBLIC_TELEGRAM_AUTH_BOT=your_bot_name
NEXT_PUBLIC_TELEGRAM_AUTH_BOT_ID=your_bot_id
